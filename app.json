{
  "expo": {
    "name": "screen-recorder-app",
    "slug": "screen-recorder-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.screenrecorderapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.screenrecorderapp"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para gravar vídeos.",
          "microphonePermission": "Permitir acesso ao microfone para gravar áudio.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir acesso às fotos para salvar gravações.",
          "savePhotosPermission": "Permitir salvar gravações na galeria.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-video"
    ]
  }
}
